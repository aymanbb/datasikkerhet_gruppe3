    "version": "2.0.0",
    "tasks": [
        {
            "label": "deploy to remote",
            "type": "shell",
            "command": "bash deploy.sh",
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": false
            }
        },

        {
            "label": "Upload current file via SCP",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-Command",
                "$rel = '${relativeFile}' -replace '^deploy\\\\steg1\\\\',''; scp '${file}' www-data@158.39.188.219:/var/www/html/steg1/$rel"
            ],
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}