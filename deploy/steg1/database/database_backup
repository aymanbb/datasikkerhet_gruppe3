# code for backup
#!/bin/bash

# Variables
DB_NAME="g3_database_actual"
DB_USER="backup-role"
DB_PASS="c3d038c875a4f8b8e141cb8362133b44"
BACKUP_DIR="var/opt/mssql/data"
TIMESTAMP=$(date +"%F")

# Backup command
mysqldump -u $DB_USER -p$DB_PASS $DB_NAME > $BACKUP_DIR/$DB_NAME-$TIMESTAMP.sql

# Zipping the backup to save storage
gzip $BACKUP_DIR/$DB_NAME-$TIMESTAMP.sql

# corn scheduling to backup the server every other midnight
0 0 1-31/2 * * /etc/cron.daily/dbbackup.sh
