CREATE DATABASE g3_database_actual;

USE g3_database_actual;

CREATE TABLE users (
	user_id int NOT NULL AUTO_INCREMENT,
	username varchar(75),
	email varchar(50),
	password varchar(255),
	is_teacher BOOLEAN NOT NULL DEFAULT FALSE,
	picture_filename varchar(50),
	subject_pin int(4),
	subject_name varchar(50),
	PRIMARY KEY (User_ID),
	UNIQUE (subject_pin)
);

CREATE TABLE messages (
	message_id int NOT NULL AUTO_INCREMENT,
	user_id int NOT NULL,
	message_body varchar (255),
	message_subject varchar(50),
	answer varchar(255),
	PRIMARY KEY (message_id),
	FOREIGN KEY (user_id) REFERENCES users(user_id)
);

CREATE TABLE comments (
 	comment_id int NOT NULL AUTO_INCREMENT,
	message_id int NOT NULL,
	comment_body varchar(255), 
	PRIMARY KEY (comment_id),
	FOREIGN KEY (message_id) REFERENCES messages(message_id)
);

DELIMITER //
CREATE PROCEDURE addStudent (IN username VARCHAR(75), IN email VARCHAR(50), IN password VARCHAR(255))
BEGIN
	INSERT INTO users (username, email, password) VALUES (username, email, password);
END //
DELIMITER ;

DELIMITER //
CREATE PROCEDURE addTeacher (IN username VARCHAR(75), IN email VARCHAR(50), IN password VARCHAR(255), IN picture_filename VARCHAR(50), IN subject_pin INT(4), IN subject_name VARCHAR(50))
BEGIN
	DECLARE teacherTrue BOOLEAN;
	SET teacherTrue = TRUE;
	INSERT INTO users (username, email, password, is_teacher, picture_filename, subject_pin, subject_name) VALUES (username, email, password, teacherTrue, picture_filename, subject_pin, subject_name);
END //
DELIMITER ;

DELIMITER //
CREATE PROCEDURE addMessage (IN user_id INT, IN message_body VARCHAR(255), IN subject_id VARCHAR(255))
BEGIN
	INSERT INTO messages (user_id, message_body, subject_id) VALUES (user_id, message_body, subject_id);
END //
DELIMITER ;

DELIMITER //
CREATE PROCEDURE addAnswerToMessage (IN message_id INT, IN answer_text VARCHAR(255))
BEGIN
	UPDATE messages SET answer = answer_text
	WHERE message_id = message_id AND answer IS NULL;
END //
DELIMITER ;
