// User + subject table 
CREATE TABLE users (
	User_ID int NOT NULL AUTO_INCREMENT,
	Name_User varchar(75),
	Email varchar(254),
	Password varchar(50),
	Is_teacher BOOLEAN NOT NULL DEFAULT FALSE,
	Picture_filename varchar(255),
	Session_cookie varchar(32),
	Subject_PIN int(4),
	Subject_name varchar(255),
	PRIMARY KEY (User_ID),
	UNIQUE (Subject_PIN)
);


// Comment table
CREATE TABLE comments (
 	Comment_ID int NOT NULL AUTO_INCREMENT,
	Message_ID int NOT NULL,
	Comment_body varchar(255), 
	PRIMARY KEY (Comment_ID),
	FOREIGN KEY (Message_ID) REFERENCES messages(Message_ID)
);


// Message table
CREATE TABLE messages (
	Message_ID int NOT NULL AUTO_INCREMENT,
	User_ID int NOT NULL,
	Message_body varchar (500),
	Answer varchar(500),
	Subject_ID int NOT NULL,
	PRIMARY KEY (Message_ID),
	FOREIGN KEY (Subject_ID) REFERENCES subject(Subject_ID)
);

// Procedure that can be called to add a student
DELIMITER //
CREATE PROCEDURE addStudent (IN student_name VARCHAR(75), IN student_email VARCHAR(254), IN student_password VARCHAR(50))
BEGIN
	INSERT INTO users (name, email, password) VALUES (student_name, student_email, student_password);
END //
DELIMITER ;


// Procedure that can be called to add a teacher
DELIMITER //
CREATE PROCEDURE addTeacher (IN teacher_name VARCHAR(75), IN teacher_email VARCHAR(254), IN teacher_password VARCHAR(50), IN teacher_subject VARCHAR(255), IN teacher_subjectPIN INT(4), IN teacher_picFilename VARCHAR(255))
BEGIN
	DECLARE teacherTrue BOOLEAN;
	SET teacherTrue = TRUE;
	INSERT INTO users (Name, Email, Password, Subject, Subject_PIN, Picture_filename, Is_teacher) VALUES (student_name, student_email, student_password, teacher_subject, teacher_subjectPIN, teacher_picFilename, teacherTrue);
END //
DELIMITER ;

